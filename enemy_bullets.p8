pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
enemy_bullets={}

--bottom invader locator helper function
	function get_bottom_invaders()
		local bottoms={}
		
		for i  in all(invaders)do
			local col=flr(i.x/12)
			
			if bottoms[col]==nil or i.y>bottoms[col].y then
				bottoms[col]=i
				end
		end
		return bottoms

	end

--- enemy shoot logic
function enemy_shoot()
	--random enemy shoots
 if rnd(1) < shoot_chance*level then
  local bottoms = get_bottom_invaders()

  -- convert table to list
  local shooters = {}
  for b in pairs(bottoms) do
   add(shooters, bottoms[b])
  end

  if #shooters > 0 then
   local shooter = shooters[flr(rnd(#shooters))+1]

   add(enemy_bullets,{
    x=shooter.x,
    y=shooter.y
   })
  end
 end
	end
	
--update bullet
function update_enemy_bullets()
	for b in all(enemy_bullets) do
--		b.y+=1
	b.y+=1+(level*0.1) --may use to increase bullet speed
		
	if b.y>128 then
		del(enemy_bullets,b)
		end
	end
end

--check collision with player
function check_enemy_hits()
	for b in all(enemy_bullets) do
	if abs(b.x-px)<5 and abs(b.y-py)<5 then
		game_state="lose"
		end
	end
end

--check collision with player bullet
--to do

-- draw enemy bullets
function draw_enemy_bullets()
		for b in all(enemy_bullets) do
		spr(8,b.x,b.y) -- draws bullets
		end
end		
