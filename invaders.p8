pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
-- invader spawn logic
function spawn_invaders()
 for y=0,3 do
  for x=0,7 do --4x8 grid
   add(invaders,{
    x=20+x*12,
    y=10+y*10,
    alive=true
   })
  end
 end
end

--updates invader when hitting wall
function update_invaders()
--- dynamic speed scaling
	local remaining = #invaders
	local half = initial_invader_count/2
	local quarter = initial_invader_count/4
	local base_speed = 0.25+(level*0.05)
	
	--speed scaling with level
	if remaining == 1 then
		inv_speed = base_speed*4
	elseif remaining <= 3 then
		inv_speed = base_speed*2
	elseif remaining <=quarter then
	inv_speed = base_speed*1.5
	elseif remaining <=half then
	inv_speed = base_speed*1.2
	else
	inv_speed = base_speed
	end
	
-- movement
-- moves horizontally
-- detects edge
-- moves reverse and down
	local edge = false
 for i in all(invaders) do
  i.x += inv_dir * inv_speed
  if i.x < 5 or i.x > 115 then
   edge = true
  end
 end

 if edge then
  inv_dir *= -1
  for i in all(invaders) do
   i.y += 6
  end
 end
end

--- invader draw
function draw_invaders()
 -- animation
 if sp_inv < 7 - sp_speed then
  sp_inv += sp_speed
 else
  sp_inv = 3
 end

 for i in all(invaders) do
  spr(sp_inv, i.x, i.y)
 end
end
