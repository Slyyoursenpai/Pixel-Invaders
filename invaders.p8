pico-8 cartridge // http://www.pico-8.com
version 41
__lua__

function _init()
score = 0
game_state="menu"
sp_inv=3
sp_speed=0.2

-- player attributes
px=60
py=120
pspd=1

--bullet attributes
bullets={}

--invader attributes
invaders = {}
inv_dir = 1
inv_speed = 0.3

for y=0,3 do
 for x=0,7 do
  add(invaders,{
   x=20+x*12,
   y=10+y*10,
   alive=true
  })
	 end
	end
end

function _update()
--menu controls
if game_state == "menu" then
	if btnp(❎) then
		start_game()
		end
		
		if btnp(🅾️) then
			ext(0)
		end
		
		return
	end


--game reset
if game_state != "play" then
	if btnp(❎) then
	start_game()
	end
	return
	end
--game state logic update
if game_state != "play" then
		return
	end

--win condition
if #invaders == 0 then
	game_state = "win"
end

--lose condition 
for i in all(invaders) do 
	if i.y > 120 then
		game_state = "lose"
		end
end

--move player
	if btn(⬅️) then
	px-=pspd
	end
	if btn(➡️) then
	px+=pspd
	end
	-- prevents offscreen movement
	px = mid(0, px, 120)
	--shoot
--	if btnp(❎) then
--	add(bullets,{x=px,y=py-4})
--	end
	-- shoot 2.0
	if btnp(❎) and #bullets==0 then
	add(bullets,{x=px,y=py-4})
	end
	
	--update bullets
	for b in all(bullets) do
	b.y-=4
		if b.y<0 then
		del(bullets,b)
		end
	end
	
	-- bullet collisions
	for b in all(bullets) do
		for i in all(invaders) do
			if abs(b.x-i.x)<5 and abs(b.y-i.y)<5 then
				del(bullets,b)
				del(invaders,i)
				score+=1
				break
				end
			end
	end
	
	-- move invaders
	local edge = false

	for i in all(invaders) do
 	i.x += inv_dir * inv_speed
 		if i.x < 5 or i.x > 115 then
  	edge = true
 		end
	end

	if edge then
 inv_dir *= -1
 	for i in all(invaders) do
  	i.y += 6
 	end
	end			
end


function _draw()
cls()

--different game screens

--game state menu
if game_state == "menu" then
	cls()
	print("invaders",24,40,7)
	--- moving invader in menu
		if sp_inv<7-sp_speed then
		sp_inv+=sp_speed
	else
		sp_inv=3
		end
		spr(sp_inv,60,38)
		spr(sp_inv,75,38)
	
	
	print("press ❎ to start",20,70,7)
	print("press 🅾️ to quit")
	return
	end

--- game state play
if game_state == "play" then
	draw_game()
	
elseif game_state == "win" then
	print("you saved the day",30,50,11)
	print("your score: "..score, 30, 65, 7)
	print("press ❎ to restart")
elseif game_state =="lose" then
	print("game over",30,60,8)
	print("your score: "..score, 30, 67, 7)
	print("print ❎ to restart")
end
end

-- drawing gameplay
function draw_game()
--draw player
 spr(17  ,px,py)
--bullets
	for b in all(bullets) do
  spr(2,b.x,b.y)
		end
--invaders
	if sp_inv<7-sp_speed then
		sp_inv+=sp_speed
	else
		sp_inv=3
		end
	for i in all(invaders) do
	spr(sp_inv,i.x,i.y)
--score
	print("score: "..score, 2, 2, 7)	
	end			
end


---start game func
function start_game()

 px = 60
 py = 120

 bullets = {}
 invaders = {}

 score = 0

 -- recreate invaders
 for y=0,3 do
  for x=0,7 do
   add(invaders,{x=16+x*12,y=16+y*10})
  end
 end

 game_state = "play"
end
