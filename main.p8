pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
#include game.p8
#include player.p8
#include bullets.p8
#include invaders.p8
#include enemy_bullets.p8
#include collisions.p8
#include ui.p8

function _init()
 init_game() --sets up game from game.p8
end

function _update()
-- controls game state logic
 if game_state == "menu" then
	 if not menu_music_playing then
  music(0) -- play menu music (0)
  menu_music_playing=true 
  end
  
  update_menu()
 elseif game_state == "play" then
  update_game()
	elseif game_state == "level_clear" then
		update_end()
	elseif game_state == "lose" then
  update_end()
 end
end

function _draw()
 cls()
-- draws state ui
 if game_state == "menu" then
  draw_menu()
 elseif game_state == "play" then
  draw_game()
 --elseif game_state == "win" then
--  draw_win()

	elseif game_state == "level_clear" then
		draw_level_clear()

 elseif game_state == "lose" then
  draw_lose()
 end
end
