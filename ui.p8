pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
-- menu ------------------------

function update_menu()
 if btnp(❎) then
  start_game()
 end

 if btnp(🅾️) then
  extcmd("shutdown")
 end
end

function draw_menu()
 print("invaders",24,40,7)

 -- moving invader (your logic)
 if sp_inv < 7 - sp_speed then
  sp_inv += sp_speed
 else
  sp_inv = 3
 end

 spr(sp_inv,60,38)
 spr(sp_inv,75,38)

 print("press ❎ to start",20,70,7)
 print("press 🅾️ to quit")
end

-- game draw -------------------

function draw_game()
 draw_player()
 draw_bullets()
 draw_invaders()
 draw_enemy_bullets()

 -- score (your placement)
 print("score: "..score, 2, 2, 7)
end

-- win / lose ------------------
--function draw_win()
-- print("you saved the day",30,50,11)
-- print("your score: "..score, 30, 65, 7)
-- print("press ❎ to restart")
--end
function draw_level_clear()
 cls()
 print("level "..level.." cleared!", 25, 50, 11)
 print("❎ next level", 35, 70, 7)
 print("🅾️ menu", 40, 85, 7)
end


function draw_lose()
 print("game over",30,60,8)
 print("your score: "..score, 30, 67, 7)
 print("press ❎ to restart")
end
